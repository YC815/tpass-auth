# T-Pass SSO 發證服務 — 環境變數範本
# 複製成 .env.local 並填入真值。.env.local 不會進 git。
# 上線（換校內 Google client、換正式網域）只需改這裡，不動任何程式。

# --- Google OAuth client（換驗證對象只改這兩個）---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- 本服務 ---
# 本服務 origin，用來組 callback URL。本機 https://auth.lvh.me:3000
AUTH_BASE_URL=https://auth.lvh.me:3000
# redirect_uri 白名單的根網域。本機 lvh.me；上線 tschoolsu.org
AUTH_ALLOWED_HOST_SUFFIX=lvh.me
# 只放行此 email 網域的使用者（不含 @）
AUTH_ALLOWED_EMAIL_DOMAIN=

# 契約 v2：可申請 per-service token 的服務 id 白名單（逗號分隔）。
# 新增服務時在此加 id（同 tpass-ops services.json 的 id），重啟 auth 即生效。
AUTH_SERVICE_IDS=portal,form,msg,appeals

# 門戶大廳網址。被單獨訪問（沒帶 redirect_uri）時，登入完把人送回這裡。
# 本機： https://portal.lvh.me:3001   上線： https://portal.tschoolsu.org
PORTAL_URL=https://portal.lvh.me:3001

# --- JWT 簽章（EdDSA / Ed25519）---
# 用 `node scripts/gen-keys.mjs` 產生，整段貼上（含雙引號）。私鑰絕不進 git。
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
# iss：必須與所有消費端的 JWT_ISSUER 完全一致。本機 https://auth.lvh.me:3000
JWT_ISSUER=https://auth.lvh.me:3000
# token 有效期（秒）。28800 = 8 小時
JWT_TTL_SECONDS=28800

# 目前簽章金鑰的 kid。留空預設 tpass-key-1（沿用既有部署，不填不影響行為）。
JWT_KID=
# 金鑰輪替 overlap 期間才填：上一把公鑰＋其 kid，讓舊 token 在切新鑰後仍能被驗過。
# 兩者都要填才會生效；平時留空。細節見 INTEGRATION.md 的「發證端金鑰輪替 runbook」。
JWT_PREV_PUBLIC_KEY=
JWT_PREV_KID=

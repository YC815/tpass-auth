# T-Pass SSO 發證服務 — 環境變數範本
# 複製成 .env.local 並填入真值。.env.local 不會進 git。
# 未來上線（換校內 Google client、開啟跨子網域）只需改這裡，不動任何程式。

# --- Google OAuth client（換驗證對象只改這兩個）---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- 本服務 ---
# 本服務 origin，用來組 callback URL。dev 用 http://localhost:3000
AUTH_BASE_URL=http://localhost:3000
# session cookie 名稱
AUTH_COOKIE_NAME=tpass_session
# cookie Domain。dev 留空＝host-only（localhost 才跑得動）。未來填 .<根網域> 例如 .tschool.tw
AUTH_COOKIE_DOMAIN=
# redirect_uri 白名單的根網域。dev 用 localhost。未來填正式根網域
AUTH_ALLOWED_HOST_SUFFIX=localhost
# 只放行此 email 網域的使用者（不含 @）。例如 chen.zone
AUTH_ALLOWED_EMAIL_DOMAIN=

# --- JWT 簽章（EdDSA / Ed25519）---
# 用 `node scripts/gen-keys.mjs` 產生，整段貼上（含雙引號）。私鑰絕不進 git。
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
# iss / aud
JWT_ISSUER=http://localhost:3000
JWT_AUDIENCE=tschool-sso
# token 有效期（秒）。28800 = 8 小時
JWT_TTL_SECONDS=28800
